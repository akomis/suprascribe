# Base URL for the application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth Configuration
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# OpenRouter API Key (for AI email analysis via Gemini)
# Used for analyzing emails and extracting subscription information
# Get your API key from: https://openrouter.ai/keys
MODEL_API_KEY=your-openrouter-api-key

# Brandfetch API Key (for fetching service logos)
BRANDFETCH_API_KEY=your-brandfetch-api-key

# Resend API Key (for contact/support forms)
RESEND_API_KEY=re-your-resend-key

# Stripe Configuration (for payment processing)
# IMPORTANT: Configure your payment link success URL in Stripe Dashboard to:
# http://localhost:3000/confirmation (for local dev)
# https://your-domain.com/confirmation (for production)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link-id
STRIPE_SECRET_KEY=sk_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
ENCRYPTION_SECRET=openssl rand -base64 32

NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com